{
  "name": "@openclaw/extension-bot-chat",
  "version": "0.1.0",
  "description": "OpenClaw BotChat channel plugin",
  "openclaw": {
    "extensions": ["./index.ts"],
    "setupEntry": "./setup-entry.ts",
    "channel": {
