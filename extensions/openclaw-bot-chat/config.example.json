{
  "backendUrl": "http://127.0.0.1:8080",
  "botKey": "ocbk_replace_with_one_time_bot_key_from_botchat_frontend",
  "botId": "replace_with_bot_uuid",
  "mqttTcpUrl": "mqtt://127.0.0.1:1883",
  "defaultTo": "group:replace_with_group_uuid_or_channel:chat/dm/user/<userId>/bot/<botId>",
  "allowFrom": ["*"],
  "stateDir": "./data",
  "historyCatchupLimit": 100,
  "openClawAgentHandler": "./examples/openai-compatible-handler.cjs",
  "permissionApprovalEnabled": true,
  "permissionApprovalHandler": "./examples/permission-approver.cjs",
  "permissionApprovalTimeoutMs": 8000,
  "permissionDeniedReply": "当前会话暂无调用权限，请联系管理员审批。"
}
