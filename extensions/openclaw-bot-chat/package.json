{
  "name": "@openclaw/extension-bot-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenClaw extension for BotChat bridge (MQTT + permission approval)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "peerDependencies": {
    "openclaw": ">=2026.4.20"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "bot-chat",
      "label": "BotChat",
      "selectionLabel": "BotChat (MQTT Bridge)",
      "detailLabel": "BotChat Bridge",
      "docsPath": "/channels/bot-chat",
      "docsLabel": "bot-chat",
      "blurb": "Bridge OpenClaw to BotChat backend and MQTT.",
      "markdownCapable": true,
      "configuredState": {
        "specifier": "./configured-state",
        "exportName": "hasBotChatConfiguredState"
      }
    },
    "install": {
      "npmSpec": "@openclaw/extension-bot-chat",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.20"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    },
    "build": {
      "openclawVersion": "2026.4.20"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    }
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "mqtt": "^5.15.1"
  }
}
