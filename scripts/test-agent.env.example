# Bot Chat backend (bootstrap/history)
BOT_CHAT_BACKEND_URL=http://127.0.0.1:8080
BOT_CHAT_BOT_KEY=ocbk_replace_with_your_bot_key

# Optional. Keep empty unless the runtime should pin a specific bot id.
BOT_CHAT_BOT_ID=

# Optional. Override broker tcp URL from bootstrap.
# BOT_CHAT_MQTT_TCP_URL=mqtt://127.0.0.1:1883

OPENAI_COMPAT_BASE_URL=https://your-openai-compatible-host/v1
OPENAI_COMPAT_API_KEY=replace_with_your_model_api_key
OPENAI_COMPAT_MODEL=gpt-4o-mini

# Optional model tuning
# OPENAI_COMPAT_SYSTEM_PROMPT=You are a concise test bot.
# OPENAI_COMPAT_TIMEOUT_MS=60000
# OPENAI_COMPAT_TEMPERATURE=0.2
# OPENAI_COMPAT_MAX_TOKENS=512
# OPENAI_COMPAT_HISTORY_TURNS=8
# OPENAI_COMPAT_MCP_MAX_TOOL_ROUNDS=6
# OPENAI_COMPAT_MCP_TOOL_TIMEOUT_MS=20000
# OPENAI_COMPAT_MCP_TOOL_RESULT_MAX_CHARS=8000
# OPENAI_COMPAT_MCP_MAX_PARALLEL=4
# OPENAI_COMPAT_MCP_ALLOWED_TOOLS=^(filesystem__|github__)
# OPENAI_COMPAT_MCP_BLOCKED_TOOLS=(delete|drop|shutdown)
# OPENAI_COMPAT_MCP_INCLUDE_SERVER_PREFIX=true
# OPENAI_COMPAT_MCP_MAX_TOOLS_PER_REQUEST=12
# OPENAI_COMPAT_MCP_TOTAL_BUDGET_MS=45000
# OPENAI_COMPAT_MAX_RETRIES=2
# OPENAI_COMPAT_RETRY_BACKOFF_MS=1200
# OPENAI_COMPAT_MEMORY_MAX_NOTES=24
# OPENAI_COMPAT_TOOL_EDIT_ENABLED=false
# OPENAI_COMPAT_TOOL_EDIT_ALLOWED_ROOTS=/workspace/openclaw-bot-chat,/tmp
# OPENAI_COMPAT_EXTRA_HEADERS={"x-api-key":"replace-if-needed"}

# Optional MCP integration for the default OpenAI-compatible handler.
# You can point to a JSON file:
# OPENAI_COMPAT_MCP_CONFIG=plugins/openclaw-bot-chat/mcp.example.json
#
# Or inline the JSON:
# OPENAI_COMPAT_MCP_SERVERS_JSON={"mcpServers":{"MiniMax":{"command":"uvx","args":["minimax-coding-plan-mcp","-y"],"env":{"MINIMAX_API_KEY":"MINIMAX_API_KEY","MINIMAX_API_HOST":"https://api.minimaxi.com"}}}}

# Optional runtime overrides
# BOT_CHAT_TEST_AGENT_KEY=test-bot
# BOT_CHAT_TEST_AGENT_HANDLER=plugins/openclaw-bot-chat/examples/openai-compatible-handler.cjs
# Optional debug alternative:
# BOT_CHAT_TEST_AGENT_HANDLER=plugins/openclaw-bot-chat/examples/echo-handler.cjs
# BOT_CHAT_TEST_AGENT_STATE_DIR=plugins/openclaw-bot-chat/data/test-agent
# BOT_CHAT_TEST_AGENT_CONFIG=plugins/openclaw-bot-chat/.test-agent.config.json
# BOT_CHAT_TEST_AGENT_CHANNEL_POLICY=open
# BOT_CHAT_HTTP_TIMEOUT_MS=15000
# BOT_CHAT_RECONNECT_BASE_MS=1000
# BOT_CHAT_RECONNECT_MAX_MS=30000
# BOT_CHAT_RUNTIME_DEBUG=1
# BOT_CHAT_LOG_BODY_MAX_LEN=600
# BOT_CHAT_LOG_SUMMARY_MAX_LEN=1500
# BOT_CHAT_TEST_AGENT_LOG_DIR=plugins/openclaw-bot-chat/data/test-agent/logs
# BOT_CHAT_TEST_AGENT_LOG_FILE=
